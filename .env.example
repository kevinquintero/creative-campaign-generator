# Copy this file to .env and fill in values as needed.
# The app runs fully without any API keys (mock generation is the default).

# Flask secret key — change this before sharing the app
SECRET_KEY=change-me-in-production

# Optional: set to "production" to disable Flask debug mode
FLASK_ENV=development

# ── Image generation provider ──────────────────────────────────────────────
# Options: mock (default, no API key needed) | openai | gemini
IMAGE_PROVIDER=mock

# Required when IMAGE_PROVIDER=openai
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Required when IMAGE_PROVIDER=gemini
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
